{
  "name": "@kleiobase/gedcom-converter",
  "version": "0.1.0",
  "description": "Convert GEDCOM files between versions, starting with FamilySearch GEDCOM 7.0.18 to GEDCOM 5.5.1.",
  "type": "module",
  "license": "MIT",
  "author": "KleioBase",
  "homepage": "https://github.com/KleioBase/gedcom-converter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KleioBase/gedcom-converter.git"
  },
  "bugs": {
    "url": "https://github.com/KleioBase/gedcom-converter/issues"
  },
  "keywords": [
    "gedcom",
    "genealogy",
    "kleiobase",
    "converter",
    "familysearch"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "convert:file": "npm run build && node scripts/convert-ged-file.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
